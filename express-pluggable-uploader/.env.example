# Configuración General del Servidor Sandbox
PORT=3000
NODE_ENV=development

# Configuración del Storage Module
# Proveedores válidos: local | s3 | supabase | gcp
STORAGE_PROVIDER=local
MAX_FILE_SIZE=10485760 # 10 MB en bytes
ALLOWED_MIMETYPES=image/png,image/jpeg,application/pdf

# Requerido solo si el proveedor es 'local'
UPLOAD_DIR=./uploads

# Requerido solo si el proveedor es 's3' o 'r2'
S3_BUCKET_NAME=my-bucket
S3_ACCESS_KEY_ID=my-access-key-id
S3_SECRET_ACCESS_KEY=my-secret-access-key
S3_REGION=us-east-1
S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com # Requerido solo para R2
S3_PUBLIC_URL=https://pub-xxxx.r2.dev            # Opcional (URL CDN o dominio público)
