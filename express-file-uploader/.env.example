# Configuración del Servidor Express
PORT=3000

# Configuración del Cargador de Archivos (Multer)
# Tamaño máximo en bytes (5MB por defecto: 5 * 1024 * 1024)
MAX_FILE_SIZE=5242880

# Directorio donde se almacenarán las subidas de archivos
UPLOAD_DIR=./uploads

# Extensiones / Tipos MIME permitidos (separados por coma)
ALLOWED_MIMETYPES=image/jpeg,image/png,image/gif,application/pdf
