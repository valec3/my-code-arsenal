# ==============================================================================
# Configuración del Servidor Express
# ==============================================================================
PORT=3000

# ==============================================================================
# Configuración General del Cargador (Multer)
# ==============================================================================
# Tamaño máximo en bytes (ej: 5MB = 5242880 bytes)
MAX_FILE_SIZE=5242880

# Extensiones / Tipos MIME permitidos (separados por coma)
ALLOWED_MIMETYPES=image/jpeg,image/png,image/gif,application/pdf

# ==============================================================================
# SELECCIÓN DEL PROVEEDOR DE ALMACENAMIENTO (Strategy)
# Opciones: local | r2 | s3 | supabase | gcp
# ==============================================================================
STORAGE_PROVIDER=local

# ==============================================================================
# Configuración de Estrategias Específicas
# ==============================================================================

# --- ESTRATEGIA LOCAL ---
UPLOAD_DIR=./uploads

# --- ESTRATEGIA CLOUDFLARE R2 / AWS S3 ---
S3_BUCKET_NAME=tu-nombre-de-bucket
S3_ENDPOINT=https://tu-account-id.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=tu-key-id
S3_SECRET_ACCESS_KEY=tu-secret-key
S3_REGION=auto
S3_PUBLIC_URL=https://pub-tu-id.r2.dev

# --- ESTRATEGIA SUPABASE STORAGE (PLANTILLA) ---
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_BUCKET=uploads

# --- ESTRATEGIA GOOGLE CLOUD STORAGE (PLANTILLA) ---
GCP_PROJECT_ID=tu-gcp-project-id
GCP_BUCKET_NAME=tu-gcp-bucket
GCP_KEY_FILE_PATH=./gcp-key.json
