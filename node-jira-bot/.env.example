# Configuración de Jira Cloud API
# Ejemplo: https://mi-organizacion.atlassian.net
JIRA_HOST=https://tu-organizacion.atlassian.net

# Tu correo electrónico asociado a la cuenta de Atlassian
JIRA_USER_EMAIL=tu-email@dominio.com

# API Token generado desde: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=tu_jira_api_token_aqui

# Clave del proyecto por defecto en Jira (ej: KAN, PROJ, etc.)
JIRA_PROJECT_KEY=KAN

# ==============================================================================
# CONFIGURACIÓN PERSONALIZADA DE TIPOS DE ISSUE (OPCIONALES)
# ==============================================================================
# Ajustá estos nombres solo si tu plantilla de Jira utiliza nombres modificados.
JIRA_EPIC_TYPE=Epic
JIRA_STORY_TYPE=Story
JIRA_SUBTASK_TYPE=Sub-task
