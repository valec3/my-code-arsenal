# Servidor NestJS
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# Módulo de Almacenamiento (Estrategia inyectada)
# Proveedores válidos: local | s3 | supabase | gcp
STORAGE_PROVIDER=local
MAX_FILE_SIZE=10485760 # 10MB en bytes
ALLOWED_MIMETYPES=image/png,image/jpeg,application/pdf

# Requerido si STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads

# Requerido si STORAGE_PROVIDER=s3
S3_BUCKET_NAME=my-bucket
S3_ACCESS_KEY_ID=my-access-key-id
S3_SECRET_ACCESS_KEY=my-secret-access-key
S3_REGION=us-east-1
S3_ENDPOINT=https://xxxx.r2.cloudflarestorage.com
S3_PUBLIC_URL=https://pub-xxxx.r2.dev
